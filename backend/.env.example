# LLM提供商选择：deepseek / openai_compatible（默认 deepseek）
LLM_PROVIDER=openai_compatible

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 备选：通义千问
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 通用 OpenAI 兼容接口（LLM_PROVIDER=openai_compatible 时生效）
OPENAI_COMPATIBLE_BASE_URL=https://x666.me/v1
OPENAI_COMPATIBLE_API_KEY=your_api_key_here
OPENAI_COMPATIBLE_MODEL=gpt-5.3-codex

# 数据库
DATABASE_URL=sqlite:///data/agri_pest.db

# 气象数据API（中国气象数据网）
WEATHER_API_KEY=your_weather_api_key_here
